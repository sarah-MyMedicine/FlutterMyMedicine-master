# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
TRUST_PROXY=1
REQUEST_BODY_LIMIT=25mb
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=66000
REQUEST_TIMEOUT_MS=30000
APP_VERSION=1.0.0
RELEASE_ID=local-dev

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin API Key (for admin routes)
ADMIN_API_KEY=your-super-secret-admin-key-change-this-in-production

# Optional: restrict browser origins in production with a comma-separated list.
# Native Flutter mobile apps usually send no Origin header, so they are unaffected.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Firebase Admin / Firestore configuration
# Use one of these:
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Firebase client API key used by the backend only for Firebase email/password login.
FIREBASE_WEB_API_KEY=

# ── SMTP (password-reset emails) ────────────────────────────────────────────
# The backend generates Firebase password-reset links via Admin SDK, then sends
# them to users via your own SMTP provider. This prevents spam-filter issues
# with Firebase's noreply@*.firebaseapp.com envelope.
#
# Gmail App Password example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false          # TLS via STARTTLS on port 587; set true only for port 465
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx  # 16-char App Password (not your Gmail password)
#   SMTP_FROM=My Medicine <you@gmail.com>
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey
#   SMTP_PASS=SG.xxxxxxxxxxxxxxxx
#   SMTP_FROM=My Medicine <noreply@yourdomain.com>
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=My Medicine <noreply@mymedicine.app>
