# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
TRUST_PROXY=1
REQUEST_BODY_LIMIT=25mb
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=66000
REQUEST_TIMEOUT_MS=30000
APP_VERSION=1.0.0
RELEASE_ID=local-dev

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin API Key (for admin routes)
ADMIN_API_KEY=your-super-secret-admin-key-change-this-in-production

# Optional: restrict browser origins in production with a comma-separated list.
# Native Flutter mobile apps usually send no Origin header, so they are unaffected.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Firebase Admin / Firestore configuration
# Use one of these:
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Firebase client API key used by the backend only for Firebase email/password login.
FIREBASE_WEB_API_KEY=
