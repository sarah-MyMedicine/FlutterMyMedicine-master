NODE_ENV=production
HOST=0.0.0.0
PORT=5000
TRUST_PROXY=1
REQUEST_BODY_LIMIT=25mb
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=66000
REQUEST_TIMEOUT_MS=30000
APP_VERSION=1.0.0
RELEASE_ID=prod-001

MONGO_URI=mongodb+srv://<atlas-user>:<atlas-password>@<cluster>.mongodb.net/mymedicine?retryWrites=true&w=majority

JWT_SECRET=<generate-a-long-random-secret>
ADMIN_API_KEY=<generate-a-second-long-random-secret>
CORS_ALLOWED_ORIGINS=

FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

WHATSAPP_ACCESS_TOKEN=<meta-whatsapp-access-token>
WHATSAPP_PHONE_NUMBER_ID=<meta-phone-number-id>
WHATSAPP_TEMPLATE_NAME=<approved-template-name>
WHATSAPP_TEMPLATE_LANGUAGE_CODE=en_US
WHATSAPP_GRAPH_API_VERSION=v21.0
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
